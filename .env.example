# ===========================
# MCP Server Credentials
# ===========================
# This file is gitignored. Never commit credentials.

# --- Atlassian Jira ---
# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_SITE_NAME=your-site          # e.g., "mycompany" from mycompany.atlassian.net
ATLASSIAN_USER_EMAIL=you@company.com
ATLASSIAN_API_TOKEN=your-api-token

# --- MCP Microsoft Office (M365 Write) ---
# Requires local clone of https://github.com/Aanerud/MCP-Microsoft-Office
# Run `npm install && npm start` in the cloned repo, then copy the bearer token
MCP_MICROSOFT_OFFICE_PATH=/path/to/MCP-Microsoft-Office
MCP_BEARER_TOKEN=your-bearer-token
